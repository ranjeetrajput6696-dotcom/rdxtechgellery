rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'ranjeetrajput6696@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Global default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Video Gallery ---
    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'id', 'platform', 'createdAt'])
        && data.title is string && data.title.size() > 0
        && data.id is string && data.id.size() > 0
        && data.platform in ['youtube', 'instagram']
        && data.createdAt == request.time;
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(videoId) && isValidVideo(incoming());
    }

    // --- Booking Validation ---
    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'scheduleDate', 'shootType', 'status', 'createdAt'])
        && data.userId == request.auth.uid
        && data.status in ['Pending', 'Confirmed', 'Completed', 'Cancelled']
        && data.shootType in ['Wedding', 'Pre-wedding', 'Other']
        && data.createdAt == request.time
        && (!data.keys().contains('paymentStatus') || data.paymentStatus in ['Unpaid', 'Partial', 'Paid'])
        && (!data.keys().contains('advanceAmount') || data.advanceAmount is number)
        && (!data.keys().contains('totalAmount') || data.totalAmount is number);
    }

    match /bookings/{bookingId} {
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming());
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().userId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['scheduleDate', 'phoneNumber', 'notes', 'shootType']) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'advanceAmount']) && 
           incoming().paymentStatus == 'Partial' && incoming().advanceAmount > 0)
        ))
      );
      allow delete: if isAdmin();
    }

    // --- Gallery Validation ---
    function isValidGalleryItem(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'category'])
        && data.title is string && data.title.size() > 0
        && data.imageUrl is string && data.imageUrl.size() > 0
        && data.category in ['Wedding', 'Pre-wedding'];
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(itemId) && isValidGalleryItem(incoming());
    }

    // --- User Profile Validation ---
    function isValidProfile(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt', 'displayName'])
        && (data.role == 'user' || (data.role == 'admin' && data.email == 'ranjeetrajput6696@gmail.com'))
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidProfile(incoming());
      allow update: if isAdmin(); // Only admins can change roles
    }
  }
}
